# Backend API connection settings
# Adjust values if running in Docker or on a remote host
# For local development: use localhost; for Docker: use service names (python-engine, python-xml-engine)
JAVA_API_HOST=java-gateway
JAVA_API_PORT=8080
JAVA_API_BASE_URL=http://${JAVA_API_HOST}:${JAVA_API_PORT}
JAVA_API_HEALTH_PATH=/health

# Optional: override if your backend runs under a different context path
# API_CONTEXT_PATH=

# Example composite values (uncomment if your tools need full URLs)
# API_PIVOT_URL=${API_BASE_URL}${API_PIVOT_PATH}
# API_HEALTH_URL=${API_BASE_URL}${API_HEALTH_PATH}

# XML generation service (used by `TkGenerateXml`)
# Browser (host) needs localhost; Java container needs service name
XML_API_HOST=localhost
XML_API_PORT=8001
XML_API_BASE_URL=http://${XML_API_HOST}:${XML_API_PORT}
XML_GENERATE_PATH=/generate-xml

# Full XML URL (optional)
# XML_GENERATE_URL=${XML_API_BASE_URL}${XML_GENERATE_PATH}

# Pivot engine service (used by `TkPivot`)
# Browser (host) needs localhost; Java container needs service name
PIVOT_API_HOST=localhost
PIVOT_API_PORT=8000
PIVOT_ENGINE_BASE_URL=http://${PIVOT_API_HOST}:${PIVOT_API_PORT}
PIVOT_API_PATH=/pivot
PIVOT_API_HEALTH_PATH=/health