# Example Environment Configuration for Java API
# Copy this file to .env and adjust values as needed
# Note: .env files are typically loaded by your shell or IDE, not automatically by Java

# ============================================
# Server Configuration
# ============================================

# Port for the Java API server
API_PORT=8080

# ============================================
# Python Services Configuration
# ============================================

# Base URL for the Python Pivot Engine
# This service processes XLSX files and performs pivot operations
PIVOT_ENGINE_BASE_URL=http://localhost:8000

# Base URL for the Python XML Generation Engine
# This service generates diploma supplement XML files
XML_API_BASE_URL=http://localhost:8001

# ============================================
# API Endpoints Configuration
# ============================================

# Path for the pivot API endpoint (on Python Pivot Engine)
PIVOT_API_PATH=/pivot

# Path for the XML generation endpoint (on Python XML Engine)
XML_GENERATE_PATH=/generate-xml

# ============================================
# JVM Configuration
# ============================================

# Java Virtual Machine options
# -Xmx: Maximum heap size
# -Xms: Initial heap size
JAVA_OPTS=-Xmx512m -Xms256m

# ============================================
# Development/Production Examples
# ============================================

# For local development (default):
# PIVOT_ENGINE_BASE_URL=http://localhost:8000
# XML_API_BASE_URL=http://localhost:8001

# For Docker Compose environment (from host):
# PIVOT_ENGINE_BASE_URL=http://localhost:8000
# XML_API_BASE_URL=http://localhost:8001

# For Docker Compose (from inside container):
# PIVOT_ENGINE_BASE_URL=http://python-engine:8000
# XML_API_BASE_URL=http://python-xml-engine:8001

# For remote services:
# PIVOT_ENGINE_BASE_URL=https://pivot-api.example.com
# XML_API_BASE_URL=https://xml-api.example.com

# ============================================
# Notes
# ============================================

# To use this file:
# 1. Copy it: cp .env.example .env
# 2. Edit .env with your specific values
# 3. Load it before running:
#    - Linux/Mac: source .env && ./run-local.sh
#    - Windows CMD: set /p=<.env && run-local.bat
#    - Windows PowerShell: Get-Content .env | ForEach-Object { if ($_ -match '^([^#][^=]+)=(.*)$') { [Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process') } }; .\run-local.ps1
